{
  "version": 2,
  "builds": [
    {
      "src": "vite.config.ts",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "(.*)",
      "dest": "/dist/$1"
    }
  ],
  "env": {
    "S3_BUCKET_NAME": "",
    "S3_REGION": "",
    "S3_ACCESS_KEY_ID": "",
    "S3_SECRET_ACCESS_KEY": "",
    "S3_ENDPOINT": "",
    "S3_FORCE_PATH_STYLE": "false",
    "S3_IMAGE_BASE_URL": "",
    "S3_IMAGE_DIR": ""
  }
}
